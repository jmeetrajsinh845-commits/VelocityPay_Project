-- =============================================================
-- QUICK VALIDATION QUERIES
-- Run these after loading to confirm data integrity
-- =============================================================

-- 1. Row counts across all tables
SELECT 'dim_customers'       AS table_name, COUNT(*) AS row_count FROM dim_customers
UNION ALL
SELECT 'fact_subscriptions',                COUNT(*)               FROM fact_subscriptions
UNION ALL
SELECT 'fact_transactions',                 COUNT(*)               FROM fact_transactions
UNION ALL
SELECT 'fact_product_usage',                COUNT(*)               FROM fact_product_usage
UNION ALL
SELECT 'fact_loan_accounts',                COUNT(*)               FROM fact_loan_accounts;

-- 2. Check for FK orphans (should return 0 for all)
SELECT 'orphan_txn_customers' AS check_name,
       COUNT(*) AS orphan_count
FROM fact_transactions ft
LEFT JOIN dim_customers dc ON ft.customer_id = dc.customer_id
WHERE dc.customer_id IS NULL

UNION ALL

SELECT 'orphan_sub_customers',
       COUNT(*)
FROM fact_subscriptions fs
LEFT JOIN dim_customers dc ON fs.customer_id = dc.customer_id
WHERE dc.customer_id IS NULL

UNION ALL

SELECT 'orphan_loan_customers',
       COUNT(*)
FROM fact_loan_accounts la
LEFT JOIN dim_customers dc ON la.customer_id = dc.customer_id
WHERE dc.customer_id IS NULL;

-- 3. Business KPI spot-check
SELECT
    ROUND(AVG(CASE WHEN is_churned THEN 1.0 ELSE 0.0 END) * 100, 2)  AS lifetime_churn_pct,
    ROUND(AVG(plan_mrr), 2)                                            AS avg_plan_mrr_inr,
    COUNT(DISTINCT customer_id)                                        AS unique_subscribed_customers
FROM fact_subscriptions;

SELECT
    ROUND(SUM(CASE WHEN payment_status = 'SUCCESS' THEN 1.0 ELSE 0 END) / COUNT(*) * 100, 2) AS success_rate_pct,
    ROUND(AVG(transaction_amount), 2)       AS avg_txn_amount_inr,
    ROUND(SUM(transaction_amount), 2)       AS total_volume_inr,
    COUNT(*)                                AS total_transactions
FROM fact_transactions;

SELECT
    ROUND(SUM(CASE WHEN npa_flag THEN 1.0 ELSE 0 END) / COUNT(*) * 100, 2) AS npa_rate_pct,
    ROUND(SUM(outstanding_principal), 2)    AS total_outstanding_inr,
    COUNT(*)                                AS total_loans
FROM fact_loan_accounts;
